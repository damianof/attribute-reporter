{
  "manifest_version": 3,
  "name": "Attribute Reporter",
  "version": "2.0.0",
  "description": "Dev Tools Extension to report on elements attributes and copy their value as text or xpath expression",
  "author": "Damiano Fusco",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "64": "icon-64.png",
    "128": "icon-128.png",
    "256": "icon-256.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "css": [
        "content-script.css"
      ],
      "run_at": "document_start"
    }
  ],
  "permissions": [],
  "devtools_page": "index.html",
  "action": {
    "default_title": "Attribute Reporter",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "64": "icon-64.png",
      "128": "icon-128.png",
      "256": "icon-256.png"
    }
  }
}
